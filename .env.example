# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored. Never commit real keys.

# Supabase mobile client values from your Supabase project settings > API.
# These are safe to expose to the app when paired with Supabase RLS.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Do not put OPENAI_API_KEY here.
# Set it as a Supabase Edge Function secret instead:
# npx supabase secrets set OPENAI_API_KEY=sk-your-openai-api-key
